# Copy this file to .env and fill values from your Upstox developer app.
# Never commit .env.

UPSTOX_CLIENT_ID=
UPSTOX_CLIENT_SECRET=
UPSTOX_REDIRECT_URI=http://localhost:8000/upstox/callback
UPSTOX_ACCESS_TOKEN=
UPSTOX_USER_AGENT=upstox-momentum-backtester/0.1

# Optional defaults for scripts.
BACKTEST_DATA_DIR=data
BACKTEST_REPORTS_DIR=reports
